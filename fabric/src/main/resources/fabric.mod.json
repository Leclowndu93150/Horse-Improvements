{
    "schemaVersion": 1,
    "id": "immersive_horse_riding",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {},
    "license": "${license}",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.leclowndu93150.horseimprovements.FabricMod"
        ],
        "mixinsquared": [
            "com.leclowndu93150.horseimprovements.HorseImprovementsMixinCanceller"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.14",
        "fabric": "*",
        "minecraft": "${minecraft_version}",
        "java": ">=21"
    }
}
